.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Logs and temp files
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig
